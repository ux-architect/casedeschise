{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "next-dev-inspect",
      "type": "shell",
      "command": "npx next dev --inspect",
      "isBackground": true,
      "problemMatcher": {
        "owner": "next",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting\\.\\.\\.",
          "endsPattern": "Ready in"
        }
      }
    }
  ]
}
